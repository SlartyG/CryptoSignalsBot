# Telegram
BOT_TOKEN=

# PostgreSQL — для Docker на VPS host=postgres; для Mac (Python локально) host=localhost
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/cryptobot

# Redis — аналогично: localhost на Mac, redis в Docker на VPS
REDIS_URL=redis://localhost:6379/0

# Crypto Pay (Phase 5)
CRYPTO_PAY_TOKEN=

# Comma-separated Telegram user IDs
ADMIN_TELEGRAM_IDS=

# Metabase (optional)
POSTGRES_PASSWORD=app
